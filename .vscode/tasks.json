{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Streamlit: Run Dashboard",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "streamlit", "run", "app.py"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "isBackground": false,
      "problemMatcher": []
    },
    {
      "label": "FastAPI: Run Server (Uvicorn)",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "uvicorn", "main:app", "--reload", "--host", "127.0.0.1", "--port", "8000"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "isBackground": false,
      "problemMatcher": []
    }
  ]
}
